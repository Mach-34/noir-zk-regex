    table[22 * 256 + 121] = 22;
    table[22 * 256 + 122] = 22;

    table
}

        
pub fn regex_match<let N: u32>(input: [u8; N]) -> BoundedVec<BoundedVec<Field, N>, 1> {
    let (substrings, start, end) = unsafe { __regex_match(input) };
    
    // "Previous" state
    let mut s: Field = 0;
    s = table[255];
    // "Next"/upcoming state
    let mut s_next: Field = 0;
    // ensure state transition occurs in the range
    let mut consecutive = true;

    // check the match
    for i in 0..N {
        let temp = input[i] as Field;
        let range = i >= start & i <= end;
        s_next = table[s * 256 + temp];
        let potential_s_next = table[temp];
        if s_next == 0 {
            s = 0;
            s_next = potential_s_next;
            consecutive = !range & consecutive;
        }
        std::as_witness(s_next);

        //let cases = [
            //(s == 21) & (s_next == 22),
            //(s == 22) & (s_next == 22),
//            (s == 22) & (s_next == 23),
//            (s == 23) & (s_next == 23)
		//];
        // idk why have to say == true
        //let found = cases.any(|case|  case == true | range == false );
        s = s_next;
        //assert(found, "no match");
    }
    // check final state
    assert((s == 22) | (s == 23), f"no match: {s}");
    
    // check indexes
    assert(start <= end, "bad start/end");
    let s_start_idx = input[start] as Field;
    std::as_witness(s_start_idx);
    let s_start: Field = table[s_start_idx];
    let s_next_start_idx = s_start * 256 + input[start + 1] as Field;
    std::as_witness(s_next_start_idx);
    let s_next_start = table[s_next_start_idx];

    println(f"start idx: {start}, start: {s_start}, start_next: {s_next_start}");
    let start_x = table[255];
    println(f"start 255: {start_x}");

    // assert(s_next_start == 1, "bad start index");        

    // get end index
    let s_next_end_idx = s * 256 + input[end - 1] as Field;
    std::as_witness(s_next_end_idx);
    let s_next_end = table[s_next_end_idx];
    assert((s_next_end == 22) | (s_next_end == 23), "bad end index");

    substrings
}

pub unconstrained fn __regex_match<let N: u32>(input: [u8; N]) -> (BoundedVec<BoundedVec<Field, N>, 1>, u32, u32) {
    // regex: email was meant for @[a-z]+
    let mut substrings: BoundedVec<BoundedVec<Field, N>, 1> = BoundedVec::new();

    // "Previous" state
    let mut s: Field = 0;
    s = table[255];
    // "Next"/upcoming state
    let mut s_next: Field = 0;

    let mut consecutive_substr = 0;
    let mut current_substring = BoundedVec::new();
    let mut start_index = 0;
    let mut end_index = 0;
    let mut complete = false;

    for i in 0..input.len() {
        let temp = input[i] as Field;
        let mut reset = false;
        s_next = table[s * 256 + temp];
        let potential_s_next = table[temp];
        if s_next == 0 {
            reset = true;
            s = 0;
            s_next = potential_s_next;
        }
        // If a substring was in the making, but the state was reset
        // we disregard previous progress because apparently it is invalid
        if (reset & (consecutive_substr == 1)) {
            current_substring = BoundedVec::new();
            consecutive_substr = 0;
        }
        // Fill up substrings
        if ((s == 0) & (s_next == 1)) {
            start_index = i;
        }
        if ((s == 21) & (s_next == 22) | (s == 22) & (s_next == 22)) {
            current_substring.push(temp);
            consecutive_substr = 1;   
        } else if ((consecutive_substr == 1) & (s_next == 0)) {
            current_substring = BoundedVec::new();
            substrings = BoundedVec::new();
            consecutive_substr = 0;
            start_index = 0;
            end_index = 0;
        } else if (s == 22) & (s_next == 23) {
            end_index = i;
            complete = true;
        } else if (consecutive_substr == 1) {
            // The substring is done so "save" it
            substrings.push(current_substring);
            // reset the substring holder for next use
            current_substring = BoundedVec::new();
            consecutive_substr = 0;
        }
        s = s_next;
        if complete == true {
            break;
        }
    }
    assert((s == 22) | (s == 23), f"no match: {s}");
    // Add pending substring that hasn't been added
    if consecutive_substr == 1 {
        substrings.push(current_substring);
        if !complete {
            end_index = input.len();
        }
    }
    (substrings, start_index, end_index)
}