pub fn regex_match<let N: u32>(input: [u8; N])  {
    // regex: from:[^<]+<?[^@<>]+@[^<>;"]+>?"?;\r\n
    let mut s = 0;
    s = table[255];
    for i in 0..input.len() {
        let s_idx = s * 256 + input[i] as Field;
        std::as_witness(s_idx);
        s = table[s_idx];
        let temp = input[i];
        println(f"State: {s}, index: {i}, char: {temp}");
    }
    println(f"Final State: {s}");
    assert((s == 57) | (s == 58) | (s == 59), "Match not found");
            
    
}
        
            